n = int(input())

contacts = {}

for _ in range(n):
	operation = input().split()

	if operation[0] == "ADD":
		name = operation[1]
		phone = operation[2]
		contacts[name] = phone

	elif operation[0] == "REMOVE":
		name = operation[1]
		if name in contacts:
			del contacts[name]

	elif operation[0] == "DISPLAY":
		if len(contacts) == 0:
			print("No contacts")
		else:
			for name in sorted(contacts):
				print(name + ":", contacts[name])
